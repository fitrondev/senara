generator client {
  provider = "prisma-client"
  output   = "../generated"
  moduleFormat = "esm"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/// Generated by Copilot
model clerk_webhook_event {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  svix_id      String   @unique
  event_type   String
  clerk_id     String?
  payload      Json
  created_at   DateTime @default(now())
  processed_at DateTime @updatedAt

  @@index([event_type])
  @@index([clerk_id])
}

/// Generated by Copilot
model user_profile {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  clerk_user_id  String    @unique
  email          String?
  first_name     String?
  last_name      String?
  username       String?
  image_url      String?
  last_event_at  DateTime  @default(now())
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  deleted_at     DateTime?

  @@index([email])
}
